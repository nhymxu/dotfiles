#!/usr/bin/env zsh

# Claude Code Profile Manager (ccpm)

config_file="$HOME/.ccpm_profiles"

# Initialize the config file if it doesn't exist
if [[ ! -f "$config_file" ]]; then
  cat << 'EOF' > "$config_file"
# Claude Code Profiles
# Group your environments by profile name inside brackets [profile_name]

[a]
ANTHROPIC_BASE_URL="http://localhost:20128/v1"
ANTHROPIC_AUTH_TOKEN="sk_9router"

[p]
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_AUTH_TOKEN="sk_prod_placeholder"
EOF
  echo "Created default profile config at $config_file"
fi

command="$1"
profile="$2"

if [[ "$command" == "list" ]]; then
  echo "Available profiles (from $config_file):"
  awk '/^\[.*\]$/ { print "  - " substr($0, 2, length($0)-2) }' "$config_file"
  exit 0
fi

if [[ "$command" == "edit" ]]; then
  ${EDITOR:-nano} "$config_file"
  exit 0
fi

if [[ "$command" == "use" ]]; then
  if [[ -z "$profile" ]]; then
    echo "Error: Please specify a profile."
    echo "Usage: ccpm use <profile>"
    exit 1
  fi

  # Check if profile exists in the file
  profile_exists=$(awk -v p="$profile" '/^\[.*\]$/ { if (substr($0, 2, length($0)-2) == p) print "yes" }' "$config_file")

  if [[ -z "$profile_exists" ]]; then
    echo "Error: Profile '$profile' not found in $config_file."
    exit 1
  fi

  # Shift the first two arguments so we can pass any extra flags to claude
  shift 2

  echo "Starting claude with profile '$profile'..."

  # Since this is a standalone script, the exported variables naturally
  # won't leak into the user's terminal.
  eval "$(awk -v p="$profile" '
    /^\[.*\]$/ { current = substr($0, 2, length($0)-2); next }
    current == p && /^[A-Za-z_]/ { print "export " $0 }
  ' "$config_file")"

  # `exec` replaces the current script process with the claude process,
  # passing along all the environment variables.
  exec claude "$@"
fi

echo "Claude Code Profile Manager (ccpm)"
echo "Usage:"
echo "  ccpm list                     - Show all available profiles"
echo "  ccpm edit                     - Open the config file to add/edit profiles"
echo "  ccpm use <profile> [args...]  - Start claude with the specified profile"
exit 1
